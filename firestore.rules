rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if request.auth.token.email == "dalinadjib1990@gmail.com" || request.auth.token.email == "admin@ais-dev.com";
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "dalinadjib1990@gmail.com" ||
        request.auth.token.email == "admin@ais-dev.com"
      );
    }

    function isAdminOnly() {
      return isAdmin();
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      return request.auth.token.email_verified == true;
    }

    // ===============================================================
    // Validation Blueprints (The "Anti-Update-Gap")
    // ===============================================================

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'photoURL', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             data.photoURL is string && data.photoURL.size() <= 1000 &&
             (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt) &&
             (!('firstName' in data) || (data.firstName is string && data.firstName.size() <= 50)) &&
             (!('lastName' in data) || (data.lastName is string && data.lastName.size() <= 50)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000)) &&
             (!('subject' in data) || (data.subject is string && data.subject.size() <= 100)) &&
             (!('school' in data) || (data.school is string && data.school.size() <= 100)) &&
             (!('wilaya' in data) || (data.wilaya is string && data.wilaya.size() <= 100)) &&
             (!('level' in data) || (data.level is string && data.level.size() <= 100)) &&
             (!('yearsOfExperience' in data) || (data.yearsOfExperience is number)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() <= 20)) &&
             (!('birthDate' in data) || (data.birthDate is string && data.birthDate.size() <= 20)) &&
             (!('role' in data) || (data.role is string && data.role.size() <= 50)) &&
             (!('rank' in data) || (data.rank is string && data.rank.size() <= 50)) &&
             (!('isProfileComplete' in data) || (data.isProfileComplete is bool)) &&
             (!('showEmail' in data) || (data.showEmail is bool)) &&
             (!('showPhone' in data) || (data.showPhone is bool)) &&
             (!('lastSeen' in data) || (data.lastSeen == request.time || (request.method == 'update' && data.lastSeen == existing().lastSeen))) &&
             (!('followers' in data) || (data.followers is list && data.followers.size() <= 10000)) &&
             (!('following' in data) || (data.following is list && data.following.size() <= 10000)) &&
             (!('friends' in data) || (data.friends is list && data.friends.size() <= 5000)) &&
             (!('blockedUsers' in data) || (data.blockedUsers is list && data.blockedUsers.size() <= 1000)) &&
             (!('bioBackground' in data) || (data.bioBackground is string && data.bioBackground.size() <= 200)) &&
             (!('bioTextColor' in data) || (data.bioTextColor is string && data.bioTextColor.size() <= 50)) &&
             (!('isActivated' in data) || (data.isActivated is bool)) &&
             (!('premiumUntil' in data) || (data.premiumUntil is timestamp)) &&
             (!('lastGenerationDate' in data) || (data.lastGenerationDate is timestamp)) &&
             (!('lastUsageResetDate' in data) || (data.lastUsageResetDate is timestamp)) &&
             (!('dailyGenCount' in data) || (data.dailyGenCount is number)) &&
             (!('dailyCorrectCount' in data) || (data.dailyCorrectCount is number)) &&
             (!('savedPreferences' in data) || (data.savedPreferences is map));
    }

    function isValidUserPrivateData(data) {
      return (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             (!('settings' in data) || (data.settings is map)) &&
             (!('reminders' in data) || (data.reminders is map));
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'authorPhoto', 'content', 'likes', 'commentCount', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 &&
             data.authorPhoto is string &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.likes is list && data.likes.size() <= 10000 &&
             data.commentCount is int && data.commentCount >= 0 &&
             (!('privacy' in data) || data.privacy in ['public', 'friends', 'private']) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000)) &&
             (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 1000)) &&
             (!('background' in data) || (data.background == null || (data.background is string && data.background.size() <= 100))) &&
             (!('reactions' in data) || data.reactions is map) &&
             (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['postId', 'authorId', 'authorName', 'authorPhoto', 'content', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.postId is string &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
             (!('parentId' in data) || (data.parentId is string)) &&
             (!('replyTo' in data) || (data.replyTo is string)) &&
             (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['recipientId', 'senderId', 'senderName', 'type', 'read', 'createdAt']) &&
             (data.senderId == request.auth.uid || isAdmin() || (data.recipientId == request.auth.uid && data.type == 'missed_call')) &&
             data.recipientId is string &&
             data.senderName is string &&
             data.type in ['like', 'comment', 'follow', 'missed_call'] &&
             data.read is bool &&
             (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['roomId', 'participants', 'senderId', 'senderName', 'seen', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.roomId is string &&
             data.participants is list && request.auth.uid in data.participants &&
             data.senderName is string &&
             data.seen is bool &&
             (!('text' in data) || (data.text is string && data.text.size() <= 2000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000)) &&
             (!('audioUrl' in data) || (data.audioUrl is string && data.audioUrl.size() <= 1000)) &&
             (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 1000)) &&
             (!('reactions' in data) || (data.reactions is map)) &&
             (!('clientCreatedAt' in data) || (data.clientCreatedAt is int)) &&
             (request.method == 'create' ? data.createdAt == request.time : data.createdAt == existing().createdAt);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if (isOwner(userId) && isValidUserProfile(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'firstName', 'lastName', 'photoURL', 'bio', 'subject', 'school', 'wilaya', 'level', 'yearsOfExperience', 'gender', 'birthDate', 'role', 'rank', 'isProfileComplete', 'showEmail', 'showPhone', 'lastSeen', 'bioBackground', 'bioTextColor', 'blockedUsers', 'isActivated', 'premiumUntil', 'lastGenerationDate', 'lastUsageResetDate', 'dailyGenCount', 'dailyCorrectCount', 'savedPreferences', 'settings'])
        )) || (
          // Social interaction: anyone can add themselves to followers/following
          isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['followers', 'following'])
        ) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users_private/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserPrivateData(incoming());
      allow update: if (isOwner(userId) && isValidUserPrivateData(incoming())) || isAdmin();
    }

    match /posts/{postId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.privacy == 'public' || resource.data.authorId == request.auth.uid);
      allow create: if isSignedIn() && isValidPost(incoming());
      allow update: if (isOwner(existing().authorId) && isValidPost(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['content', 'privacy', 'imageUrl', 'videoUrl', 'background', 'reactions'])
        )) || (
          // Social interaction: anyone can like or increment comment count
          isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'commentCount', 'reactions'])
        ) || isAdmin();
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    match /comments/{commentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidComment(incoming()) && exists(/databases/$(database)/documents/posts/$(incoming().postId));
      allow update: if (isOwner(existing().authorId) && isValidComment(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['content'])
        )) || isAdmin();
      allow delete: if isOwner(existing().authorId) || (isSignedIn() && exists(/databases/$(database)/documents/posts/$(existing().postId)) && get(/databases/$(database)/documents/posts/$(existing().postId)).data.authorId == request.auth.uid) || isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isOwner(resource.data.recipientId) || isAdmin();
      allow list: if isOwner(resource.data.recipientId) || isAdmin();
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if (isOwner(existing().recipientId) && incoming().diff(existing()).affectedKeys().hasOnly(['read'])) || isAdmin();
      allow delete: if isOwner(existing().recipientId) || isAdmin();
    }

    match /messages/{messageId} {
      allow get: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && isValidMessage(incoming());
      allow update: if (isSignedIn() && request.auth.uid in existing().participants && (
          incoming().diff(existing()).affectedKeys().hasOnly(['seen', 'reactions', 'deletedFor'])
        )) || isAdmin();
      allow delete: if (isOwner(existing().senderId)) || isAdmin();
    }

    match /invitations/{invitationId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow update: if isSignedIn() && (request.auth.uid in existing().participants);
      allow delete: if isSignedIn() && (request.auth.uid in existing().participants);
    }

    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(existing().sellerId) || isAdmin();
      allow delete: if isOwner(existing().sellerId) || isAdmin();
    }

    match /calls/{callId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.recipientId);
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow update: if isSignedIn() && (request.auth.uid == existing().senderId || request.auth.uid == existing().recipientId);
      allow delete: if isSignedIn() && (request.auth.uid == existing().senderId || request.auth.uid == existing().recipientId);
    }

    match /typing/{roomId} {
      allow read, write: if isSignedIn() && (roomId == 'global' || roomId.matches('.*' + request.auth.uid + '.*'));
    }

    match /activation_codes/{codeId} {
      // Admin has full control
      allow read, write: if isAdmin();
      
      // Regular users can query to find a code and use it
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Connection test path
    match /_connection_test_/{docId} {
      allow read, write: if true;
    }
  }
}
